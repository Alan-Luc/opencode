{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "darkStep1": "#0a0a0a",
    "darkStep2": "#141414",
    "darkStep3": "#1e1e1e",
    "darkStep4": "#282828",
    "darkStep5": "#323232",
    "darkStep6": "#3c3c3c",
    "darkStep7": "#484848",
    "darkStep8": "#606060",
    "lightStep1": "#ffffff",
    "lightStep2": "#fafafa",
    "lightStep3": "#f5f5f5",
    "lightStep6": "#d4d4d4",
    "lightStep7": "#b8b8b8",
    "lightStep8": "#a0a0a0",

    "fujiWhite": "#DCD7BA",
    "fujiGray": "#727169",
    "dragonGray2": "#9e9b93",
    "dragonPink": "#a292a3",
    "dragonBlue2": "#859fac",
    "dragonAqua": "#8ea49e",
    "dragonRed": "#c4746e",
    "dragonYellow": "#c4b28a",
    "dragonOrange": "#b6927b",
    "dragonGreen": "#699469",
    "dragonGreen2": "#8a9a7b",
    "dragonViolet": "#8992a7",
    "dragonBlue": "#658594",
    "dragonBlue5": "#435965",

    "lightBg": "#F2E9DE",
    "lightPaper": "#EAE4D7",
    "lightText": "#54433A",
    "lightGray": "#9E9389"
  },
  "theme": {
    "primary": { "dark": "dragonBlue2", "light": "dragonBlue5" },
    "secondary": { "dark": "dragonViolet", "light": "dragonViolet" },
    "accent": { "dark": "dragonPink", "light": "dragonPink" },
    "error": { "dark": "dragonRed", "light": "dragonRed" },
    "warning": { "dark": "dragonYellow", "light": "dragonYellow" },
    "success": { "dark": "dragonGreen", "light": "dragonGreen" },
    "info": { "dark": "dragonBlue", "light": "dragonBlue" },

    "text": { "dark": "fujiWhite", "light": "lightText" },
    "textMuted": { "dark": "fujiGray", "light": "lightGray" },

    "background": { "dark": "darkStep1", "light": "lightStep1" },
    "backgroundPanel": { "dark": "darkStep2", "light": "lightStep2" },
    "backgroundElement": { "dark": "darkStep3", "light": "lightStep3" },
    "border": { "dark": "darkStep7", "light": "lightStep7" },
    "borderActive": { "dark": "darkStep8", "light": "lightStep8" },
    "borderSubtle": { "dark": "darkStep6", "light": "lightStep6" },

    "diffAdded": { "dark": "dragonGreen", "light": "dragonGreen" },
    "diffRemoved": { "dark": "dragonRed", "light": "dragonRed" },
    "diffContext": { "dark": "fujiGray", "light": "lightGray" },
    "diffHunkHeader": { "dark": "dragonBlue5", "light": "dragonBlue5" },
    "diffHighlightAdded": { "dark": "#72a072", "light": "#72a072" },
    "diffHighlightRemoved": { "dark": "#cc928e", "light": "#cc928e" },
    "diffAddedBg": { "dark": "#27302a", "light": "#d5e5d5" },
    "diffRemovedBg": { "dark": "#302530", "light": "#f7d8db" },
    "diffContextBg": { "dark": "darkStep2", "light": "lightStep2" },
    "diffLineNumber": { "dark": "#8f8f8f", "light": "#595959" },
    "diffAddedLineNumberBg": { "dark": "#1f2a22", "light": "#c5d5c5" },
    "diffRemovedLineNumberBg": { "dark": "#2d1f26", "light": "#e7c8cb" },

    "markdownText": { "dark": "fujiWhite", "light": "lightText" },
    "markdownHeading": { "dark": "dragonViolet", "light": "dragonViolet" },
    "markdownLink": { "dark": "dragonBlue2", "light": "dragonBlue5" },
    "markdownLinkText": { "dark": "dragonAqua", "light": "dragonAqua" },
    "markdownCode": { "dark": "dragonGreen2", "light": "dragonGreen2" },
    "markdownBlockQuote": { "dark": "fujiGray", "light": "lightGray" },
    "markdownEmph": { "dark": "dragonYellow", "light": "dragonYellow" },
    "markdownStrong": { "dark": "dragonOrange", "light": "dragonOrange" },
    "markdownHorizontalRule": { "dark": "fujiGray", "light": "lightGray" },
    "markdownListItem": { "dark": "dragonBlue2", "light": "dragonBlue5" },
    "markdownListEnumeration": { "dark": "dragonAqua", "light": "dragonAqua" },
    "markdownImage": { "dark": "dragonBlue2", "light": "dragonBlue5" },
    "markdownImageText": { "dark": "dragonAqua", "light": "dragonAqua" },
    "markdownCodeBlock": { "dark": "fujiWhite", "light": "lightText" },

    "syntaxComment": { "dark": "fujiGray", "light": "lightGray" },
    "syntaxKeyword": { "dark": "dragonPink", "light": "dragonPink" },
    "syntaxFunction": { "dark": "dragonBlue2", "light": "dragonBlue5" },
    "syntaxVariable": { "dark": "fujiWhite", "light": "lightText" },
    "syntaxString": { "dark": "dragonGreen2", "light": "dragonGreen2" },
    "syntaxNumber": { "dark": "dragonPink", "light": "dragonPink" },
    "syntaxType": { "dark": "dragonAqua", "light": "dragonAqua" },
    "syntaxOperator": { "dark": "dragonRed", "light": "dragonRed" },
    "syntaxPunctuation": { "dark": "dragonGray2", "light": "lightGray" }
  }
}
